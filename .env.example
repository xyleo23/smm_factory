# ── Telegram ─────────────────────────────────────────────────────────────────
BOT_TOKEN=
ADMIN_CHAT_ID=

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
NANO_BANANA_API_KEY=

# ── Database (PostgreSQL via Docker) ─────────────────────────────────────────
# asyncpg URL is used in .env; the sync SQLAlchemy engine strips "+asyncpg" automatically.
DATABASE_URL=postgresql+asyncpg://smm:password@postgres:5432/smm_factory

# PostgreSQL container credentials (must match DATABASE_URL above)
POSTGRES_DB=smm_factory
POSTGRES_USER=smm
POSTGRES_PASSWORD=password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Optional publishers ───────────────────────────────────────────────────────
VC_SESSION_TOKEN=
RBC_LOGIN=
RBC_PASSWORD=
